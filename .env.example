# Database Configuration
POSTGRES_DB=shopping_lists
POSTGRES_USER=shopping_user
POSTGRES_PASSWORD=shopping_pass
POSTGRES_PORT=5432

# Application Ports
FRONTEND_PORT=80
BACKEND_PORT=8080

# List Retention Configuration
LIST_RETENTION_DAYS=30

# Frontend Environment Variables
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# Production overrides (copy to .env and modify as needed)
# POSTGRES_PASSWORD=your_secure_password_here
# VITE_API_URL=https://your-domain.com
# VITE_WS_URL=wss://your-domain.com

# Push Notifications (Web Push / VAPID)
# Generate VAPID keys by running: npx web-push generate-vapid-keys
# VAPID_SUBJECT must start with "mailto:" or "https://"
VAPID_SUBJECT=mailto:your-email@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=