{
  "name": "shoppimo-frontend",
  "description": "Shoppimo frontend - Real-time collaborative shopping list app",
  "version": "5.0.0",
  "type": "module",
  "license": "MIT",
  "author": "Shoppimo Contributors",
  "homepage": "https://github.com/hechi/shoppimo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hechi/shoppimo.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/hechi/shoppimo/issues"
  },
  "keywords": [
    "shopping",
    "list",
    "collaborative",
    "real-time",
    "websocket",
    "react",
    "pwa"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.js",
    "test-pwa": "npm run build && npm run preview"
  },
  "dependencies": {
    "i18next": "^25.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cypress": "^15.5.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.3",
    "workbox-precaching": "^7.4.0"
  }
