<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender for container logs -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- File appender for persistent logging (optional in containers) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/app/logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/app/logs/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- JSON appender for structured logging (useful for log aggregation) -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp/>
                <logLevel/>
                <loggerName/>
                <mdc/>
                <message/>
                <stackTrace/>
            </providers>
        </encoder>
    </appender>
    
    <!-- Conditional configuration based on environment -->
    <springProfile name="production">
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
    
    <springProfile name="!production">
        <root level="DEBUG">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>
    
    <!-- Default configuration if no profile is set -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    
    <!-- Application-specific loggers -->
    <logger name="com.shoppinglist" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT"/>
    </logger>
    
    <!-- Third-party library loggers -->
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>
    <logger name="org.postgresql" level="INFO"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>
    <logger name="org.jetbrains.exposed" level="INFO"/>
    
    <!-- WebSocket and connection logging -->
    <logger name="io.ktor.websocket" level="DEBUG"/>
    <logger name="com.shoppinglist.websocket" level="DEBUG"/>
    
    <!-- Database connection logging -->
    <logger name="com.shoppinglist.database" level="DEBUG"/>
    
    <!-- Reduce noise from health checks -->
    <logger name="com.shoppinglist.plugins.Routing" level="INFO"/>
</configuration>